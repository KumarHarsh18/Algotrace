# Database (Railway provides this automatically when you add PostgreSQL plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/algotrace"

# JWT — generate a random 64-char string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here"

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Callback URL (change to production URL when deploying)
GITHUB_CALLBACK_URL="http://localhost:5000/api/auth/github/callback"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Server port
PORT=5000

# Node environment
NODE_ENV="development"
